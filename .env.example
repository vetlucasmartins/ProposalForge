# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional Supabase runtime values for a future/auth-enabled phase.
# The current UI demo runs without these values.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Optional legacy fallback if your project has not migrated to publishable keys.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase values. Never expose this as NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PDF_BUCKET=proposal-pdfs

# Optional LLM provider values for a future generation endpoint.
LLM_PROVIDER=
LLM_MODEL=
OPENAI_API_KEY=

# Server-only security secrets for future public sharing/acceptance flows.
ACCEPTANCE_IP_HASH_SECRET=
SHARE_TOKEN_SECRET=

# Optional PDF renderer value for a future export endpoint.
PDF_RENDERER=
